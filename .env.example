# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site
NEXT_PUBLIC_SITE_URL=https://listentruecrime.com

# Admin — comma-separated email addresses that get admin access
ADMIN_EMAILS=admin@listentruecrime.com

# Newsletter — set NEWSLETTER_PROVIDER to one of: beehiiv | convertkit | mailchimp | none
NEWSLETTER_PROVIDER=none

# Beehiiv (if using Beehiiv)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ConvertKit (if using ConvertKit)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Mailchimp (if using Mailchimp)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=us1
